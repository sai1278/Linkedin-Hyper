# LinkedIn Dashboard — Environment Variables

# API server base URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Internal API secret key (must match the automation backend)
API_SECRET=

# Proxy auth: JSON map of token -> role (`user` or `admin`).
# Example: {"dev-user-token":"user","dev-admin-token":"admin"}
PROXY_AUTH_TOKENS=

# Optional cookie name used when sending auth token in cookies.
PROXY_AUTH_COOKIE_NAME=proxy_session

# WebSocket URL for real-time updates
NEXT_PUBLIC_WS_URL=ws://localhost:3001
