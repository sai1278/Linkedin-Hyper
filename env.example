# LinkedIn Dashboard — Environment Variables

# ==========================================
# Frontend Configuration
# ==========================================

# Internal API secret key (must match the automation backend)
API_SECRET=

# API server base URL for frontend
# Use http://localhost:3001 for local dev, or http://worker:3001 in Docker
API_URL=http://localhost:3001

# Public API URL for client-side fetching
NEXT_PUBLIC_API_URL=http://localhost:3001

# Proxy auth: JSON map of token -> role (`user` or `admin`).
# Example: {"dev-user-token":"user","dev-admin-token":"admin"}
PROXY_AUTH_TOKENS=

# Optional cookie name used when sending auth token in cookies.
PROXY_AUTH_COOKIE_NAME=proxy_session

# WebSocket URL for real-time updates
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Optional: bearer token required by Next.js API routes
API_ROUTE_AUTH_TOKEN=

# ==========================================
# Worker Configuration
# ==========================================

# Encryption key for session cookies (AES-256-GCM, must be 64 hex chars / 32 bytes)
# Generate with: openssl rand -hex 32
SESSION_ENCRYPTION_KEY=

# Comma-separated list of LinkedIn account IDs to run
ACCOUNT_IDS=

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Optional proxy for all Playwright traffic
PROXY_URL=
