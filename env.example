# LinkedIn Dashboard — Environment Variables

# ==========================================
# Frontend Configuration
# ==========================================

# Internal worker API secret key.
# Generate with: openssl rand -hex 32
API_SECRET=

# API server base URL for frontend
# Use http://localhost:3001 for local dev, or http://worker:3001 in Docker
API_URL=http://localhost:3001

# Public app/API URL used by the browser.
# In Docker/Nginx production, this should be your public frontend origin, not port 3001.
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Proxy auth: JSON map of token -> role (`user` or `admin`).
# Example: {"dev-user-token":"user","dev-admin-token":"admin"}
PROXY_AUTH_TOKENS=

# Optional cookie name used when sending auth token in cookies.
PROXY_AUTH_COOKIE_NAME=proxy_session

# WebSocket URL for real-time updates
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Bearer token required for non-browser automation against public Next.js /api routes.
# Generate with: openssl rand -base64 48 | tr -d '\n'
API_ROUTE_AUTH_TOKEN=

# ==========================================
# Dashboard Authentication (NEW)
# ==========================================

# Dashboard login password (plaintext, use strong random string)
# Generate with: openssl rand -base64 32
DASHBOARD_PASSWORD=

# JWT signing secret (min 32 chars for HS256)
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Dashboard session duration in seconds (2592000 = 30 days)
SESSION_MAX_AGE=2592000

# Login brute-force throttling
LOGIN_RATE_LIMIT_WINDOW_SEC=900
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# ==========================================
# Worker Configuration
# ==========================================

# Encryption key for session cookies (AES-256-GCM, must be 64 hex chars / 32 bytes)
# Generate with: openssl rand -hex 32
SESSION_ENCRYPTION_KEY=

# LinkedIn account session TTL in Redis (days)
SESSION_TTL_DAYS=30

# Postgres password used by the docker-compose postgres service
# Generate with: openssl rand -hex 16
DB_PASSWORD=

# Comma-separated list of LinkedIn account IDs to run
ACCOUNT_IDS=

# Optional: comma-separated account IDs to exclude from scheduled and bulk message sync.
# Manual single-account actions can still target these accounts explicitly.
MESSAGE_SYNC_DISABLED_ACCOUNT_IDS=

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Public frontend origins trusted for cookie-authenticated mutations.
# Example: https://app.example.com,https://admin.example.com
TRUSTED_ORIGINS=

# Optional proxy for all Playwright traffic
PROXY_URL=
