# Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# URL of your Strapi backend
NEXT_PUBLIC_STRAPI_URL=https://acumen-strapi-beta.onrender.com

# Private Strapi API token (server-side only — never exposed to browser)
# Generate in Strapi Admin → Settings → API Tokens
STRAPI_API_TOKEN=your-strapi-api-token

# ----------------------------------------------------------------------------
# TENANT CONFIGURATION
# ----------------------------------------------------------------------------
# The slug of the tenant this frontend deployment serves.
# Must match the slug in your Strapi Tenant collection.
#
# Examples:
#   NEXT_PUBLIC_TENANT_SLUG=glynac-ai        → serves Glynac AI blog posts
#   NEXT_PUBLIC_TENANT_SLUG=regulatethis     → serves RegulateThis blog posts
#   NEXT_PUBLIC_TENANT_SLUG=sylvian          → serves Sylvan blog posts
#
# How tenant scoping works:
#   - Browser requests: Strapi resolves the tenant from the Origin header
#     (the domain the user is visiting — e.g. glynac.ai → glynac-ai tenant)
#   - Server-side (SSR/SSG): The frontend sends X-Tenant-Slug header using
#     this env var so Strapi scopes the results before returning them.
#
NEXT_PUBLIC_TENANT_SLUG=glynac-ai
