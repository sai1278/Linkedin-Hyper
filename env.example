# Linkedin-Hyper Environment Variables

# ==========================================
# Frontend / BFF
# ==========================================

# Internal worker API secret key used by the Next.js BFF when forwarding to the worker.
# Generate with: openssl rand -hex 32
API_SECRET=change-me

# Internal worker base URL used by the frontend container.
API_URL=http://127.0.0.1:3001

# Public browser-facing API base.
# Use your deployed frontend origin in production, or /api when reverse proxying same-origin requests.
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:3002

# Public WebSocket endpoint. Include /ws in production.
NEXT_PUBLIC_WS_URL=ws://YOUR_SERVER_IP:3002/ws

# Trusted browser origins for cookie-authenticated mutations.
TRUSTED_ORIGINS=http://YOUR_SERVER_IP:3002,http://127.0.0.1:3002

# Preferred service auth: array of hashed tokens with metadata.
# Example:
# SERVICE_AUTH_TOKENS=[{"id":"ci-admin","role":"admin","tokenHash":"<sha256-hex>","expiresAt":"2026-12-31T23:59:59.000Z","createdAt":"2026-05-01T00:00:00.000Z","rotatedAt":null,"audiences":["proxy","backend-api"]}]
SERVICE_AUTH_TOKENS=[]

# Compatibility-only legacy proxy auth map.
PROXY_AUTH_TOKENS=
PROXY_AUTH_COOKIE_NAME=proxy_session

# Compatibility-only bearer token for public /api operator automation.
API_ROUTE_AUTH_TOKEN=change-me
ALLOW_STATIC_SERVICE_TOKENS=false

# Incorrect legacy typos are ignored. Use these exact names only:
# - NEXT_PUBLIC_API_URL
# - NEXT_PUBLIC_WS_URL

# ==========================================
# Dashboard Authentication / Authorization
# ==========================================

# Bootstrap admin users by email.
INITIAL_ADMIN_EMAILS=admin@example.com

# Optional account assignments for non-admin users.
USER_ACCOUNT_ACCESS={"admin@example.com":["saikanchi130"]}

# JWT signing secret for dashboard sessions.
JWT_SECRET=change-me

# Session duration in seconds.
SESSION_MAX_AGE=2592000

# Login brute-force throttling.
LOGIN_RATE_LIMIT_WINDOW_SEC=900
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# ==========================================
# Send / Sync Rate Limits
# ==========================================
RATE_LIMIT_MESSAGES_SENT=25
RATE_LIMIT_MESSAGES_SENT_HOURLY=8
RATE_LIMIT_MESSAGES_SENT_MIN_GAP_SEC=45
RATE_LIMIT_MESSAGES_SENT_BURST_LIMIT=3
RATE_LIMIT_MESSAGES_SENT_BURST_WINDOW_SEC=300

# ==========================================
# Worker / Sessions
# ==========================================

# AES-256-GCM session encryption key (64 hex chars / 32 bytes).
SESSION_ENCRYPTION_KEY=change-me
SESSION_TTL_DAYS=30

# Managed LinkedIn account IDs.
ACCOUNT_IDS=saikanchi130
MESSAGE_SYNC_DISABLED_ACCOUNT_IDS=optional-account-id

# Optional upstream proxy.
PROXY_URL=

# ==========================================
# Database / Redis
# ==========================================
DB_PASSWORD=change-me
REDIS_PASSWORD=change-me
REDIS_HOST=localhost
REDIS_PORT=6379

DATABASE_URL=postgresql://linkedinuser:DB_PASSWORD@postgres:5432/linkedin_db
POSTGRES_URL=postgresql://linkedinuser:DB_PASSWORD@postgres:5432/linkedin_db
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379
