# Redis password used by both redis service and clients
REDIS_PASSWORD=change_this_to_a_secure_password_123

# Callers must send this in X-Api-Key header
API_SECRET=your_api_secret_key_here

# Exactly 64 hex characters (32 bytes), generate with: openssl rand -hex 32
SESSION_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Session age warning threshold in hours. Sessions older than this emit a warning log. Default: 12
SESSION_MAX_AGE_HOURS=12

# Format http://user:pass@host:port, leave blank to disable proxy
PROXY_URL=

# Set to production
NODE_ENV=production
