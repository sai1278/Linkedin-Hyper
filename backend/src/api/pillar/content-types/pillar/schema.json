{
    "kind": "collectionType",
    "collectionName": "pillars",
    "info": {
        "singularName": "pillar",
        "pluralName": "pillars",
        "displayName": "Pillar",
        "description": "Content pillars for blog categorization"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true,
            "unique": true
        },
        "slug": {
            "type": "uid",
            "targetField": "name",
            "required": true
        },
        "subtitle": {
            "type": "string",
            "required": true,
            "maxLength": 100
        },
        "description": {
            "type": "text",
            "required": true
        },
        "order": {
            "type": "integer",
            "required": true
        },
        "details": {
            "type": "component",
            "repeatable": true,
            "component": "shared.pillar-details",
            "max": 10
        },
        "articles": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::article.article",
            "mappedBy": "pillar"
        },
        "tenant": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::tenant.tenant",
            "inversedBy": "pillars"
        }
    }
}