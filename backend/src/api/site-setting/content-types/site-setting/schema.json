{
    "kind": "collectionType",
    "collectionName": "site_settings",
    "info": {
        "singularName": "site-setting",
        "pluralName": "site-settings",
        "displayName": "Site Settings",
        "description": "Per-tenant site settings including analytics and tracking"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "siteName": {
            "type": "string",
            "required": true,
            "maxLength": 100
        },
        "siteDescription": {
            "type": "text"
        },
        "gtmId": {
            "type": "string",
            "maxLength": 50
        },
        "gtmEnabled": {
            "type": "boolean",
            "default": false
        },
        "googleAnalyticsId": {
            "type": "string",
            "maxLength": 50
        },
        "gaEnabled": {
            "type": "boolean",
            "default": false
        },
        "metaPixelId": {
            "type": "string",
            "maxLength": 50
        },
        "metaPixelEnabled": {
            "type": "boolean",
            "default": false
        },
        "customHeadScripts": {
            "type": "text"
        },
        "customBodyScripts": {
            "type": "text"
        },
        "metaTitle": {
            "type": "string",
            "maxLength": 70
        },
        "metaDescription": {
            "type": "text",
            "maxLength": 160
        },
        "keywords": {
            "type": "text"
        },
        "ogImage": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "tenant": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::tenant.tenant",
            "inversedBy": "siteSettings"
        }
    }
}