{
    "collectionName": "components_blog_authors",
    "info": {
        "displayName": "Author",
        "description": "Blog post author information"
    },
    "options": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true,
            "maxLength": 100,
            "description": "Author full name (e.g., 'Sarah Mitchell')"
        },
        "role": {
            "type": "string",
            "required": true,
            "maxLength": 150,
            "description": "Author job title (e.g., 'Head of Product, Glynac')"
        },
        "description": {
            "type": "string",
            "required": false,
            "maxLength": 300,
            "description": "Short author description shown under the author widget (max 300 characters)"
        },
        "bio": {
            "type": "text",
            "required": false,
            "maxLength": 500
        },
        "avatar": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "linkedin": {
            "type": "string",
            "required": false,
            "maxLength": 200
        },
        "twitter": {
            "type": "string",
            "required": false,
            "maxLength": 200
        }
    }
}